# JWT TTL (optional)
# ACCESS_TOKEN_TTL=168h
# REFRESH_TOKEN_TTL=720h
# EMAIL_TOKEN_TTL=24h

# SMTP — 生产用阿里云邮件推送；开发可留空（邮件打印到控制台）
MAIL_FROM=noreply@oxelia51.com
MAIL_FROM_NAME=Oxelia51
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true

# 本地项目扫描根目录（POST /api/admin/tools/scan-local）
