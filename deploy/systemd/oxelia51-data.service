[Unit]
Description=Oxelia51 PostgreSQL and Redis (Docker Compose)
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/Oxelia51/deploy/docker
EnvironmentFile=-/opt/Oxelia51/deploy/docker/.env
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
