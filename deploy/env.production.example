# 复制为 /opt/Oxelia51/backend/.env（勿提交真实密钥）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=CHANGE_ME_STRONG
DB_NAME=oxelia51

SERVER_PORT=8080
LISTEN_ADDR=127.0.0.1:8080
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM

REDIS_ADDR=127.0.0.1:6379

APP_PUBLIC_URL=https://oxelia51.com
ADMIN_INITIAL_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

MAIL_FROM=noreply@oxelia51.com
MAIL_FROM_NAME=Oxelia51
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true

# 网关 loopback 转发 DormGuard（ADR-006/007）
TOOL_API_BASE_DORMGUARD=http://127.0.0.1:8000

# 腾讯云服务器健康检查端点（F3：管理面板远程监控，未来启用）
# TENCENT_HEALTH_URL=http://118.25.138.177/api/health

# 服务器上无 code 目录时可留空；工具数据由 deploy/seed-tools.sql 初始化
CODE_ROOT=

# SmartKB 智能知识库（集成在 backend 内，非独立工具）
# 设计文档：docs/superpowers/specs/2026-07-13-smartkb-toolfab-design.md §4.8
# 后端读取由 P4/Qoder 阶段实现，当前留空使用默认值即可
# KB_EMBEDDING_MODEL=text-embedding-3-small
# KB_CHAT_MODEL=gpt-4o-mini
# KB_CHUNK_SIZE=1000
# KB_CHUNK_OVERLAP=100
# KB_TOP_K=5
# KB_CRON=0 3 * * *
